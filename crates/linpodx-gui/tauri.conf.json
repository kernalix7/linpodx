{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "linpodx",
  "version": "0.1.4",
  "identifier": "io.kodenet.linpodx",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "linpodx",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "linpodx container manager",
    "longDescription": "A thin Tauri shell that displays the linpodx daemon's built-in web UI."
  }
}
